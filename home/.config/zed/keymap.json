// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    // These override Zed's built-in defaults (cmd-0 opens git panel by default)
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "cmd-shift-{": "workspace::ActivatePaneLeft",
      "cmd-shift-}": "workspace::ActivatePaneRight",
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-2": "outline_panel::ToggleFocus",
      "cmd-k": "git_panel::ToggleFocus",
      "cmd-3": "agent::ToggleFocus",
      "cmd-4": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-w": "editor::SelectLargerSyntaxNode",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-0": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-2": "outline_panel::ToggleFocus",
      "cmd-k": "git_panel::ToggleFocus",
      "cmd-3": "agent::ToggleFocus",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-k": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "OutlinePanel",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-2": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-3": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Pane",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-w": null,
      "cmd-\\": "pane::SplitRight",
      "cmd-|": "pane::SplitHorizontal",
      "cmd-shift-backspace": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-0": "terminal_panel::ToggleFocus",
      "cmd-w": "editor::SelectLargerSyntaxNode",
      "cmd-\\": "pane::SplitRight",
      "cmd-|": "pane::SplitHorizontal",
      "cmd-shift-backspace": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
]
