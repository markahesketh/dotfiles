{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/validate-commit.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/title-from-prompt.sh --reset",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/markhesketh/.codex/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/notify-done.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/title-from-prompt.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}