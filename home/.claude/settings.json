{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoMemoryEnabled": false,
  "awaySummaryEnabled": false,
  "disableArtifact": true,
  "disableBundledSkills": true,
  "disableClaudeAiConnectors": true,
  "disableDeepLinkRegistration": "disable",
  "disableRemoteControl": true,
  "disableSideloadFlags": true,
  "disableWorkflows": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "dexory@dotfiles": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/markhesketh/.claude/hooks/rtk-rewrite.sh",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/hooks/route-commit-to-skill.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/markhesketh/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeGitInstructions": false,
  "model": "opus[1m]",
  "permissions": {
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git rebase *)"
    ],
    "defaultMode": "auto",
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "EnterWorktree",
      "ExitWorktree",
      "ShareOnboardingGuide",
      "AskUserQuestion"
    ]
  },
  "showClearContextOnPlanAccept": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 60,
    "type": "command"
  },
  "theme": "light"
}