{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "EnterWorktree",
      "ExitWorktree",
      "ShareOnboardingGuide",
      "AskUserQuestion"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git rebase *)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "disableClaudeAiConnectors": true,
  "disableBundledSkills": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-attention.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-done.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/pane-title-from-prompt.sh --reset"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/pane-title-from-prompt.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/markhesketh/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/route-commit-to-skill.sh"
          }
        ]
      }
    ]
  },
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "dexory@dotfiles": true,
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  },
  "disableSideloadFlags": true,
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "showClearContextOnPlanAccept": true,
  "autoMemoryEnabled": false,
  "theme": "light",
  "disableDeepLinkRegistration": "disable"
}
